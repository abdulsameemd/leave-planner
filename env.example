# ─────────────────────────────────────────────────────
# DigitalX AI Proxy — Environment Variables
# ─────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Port (default: 3000)
PORT=3000

# CORS — restrict to your domain in production
ALLOWED_ORIGIN=*

# ─────────────────────────────────────────────────────
# EMAIL (automated notifications) — optional but recommended
# ─────────────────────────────────────────────────────
# For Office 365 / Outlook corporate email:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@dewa.gov.ae
SMTP_PASS=your-email-password

# Manager details (override defaults)
MANAGER_EMAIL=abdulsamee.mohammed@dewa.gov.ae
MANAGER_NAME=Abdul Samee Mohammed
